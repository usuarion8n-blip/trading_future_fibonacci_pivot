# ==========================
# Supabase
# ==========================
SUPABASE_URL=https://<tu-project-id>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<tu-service-role-key>

# ==========================
# Tablas de Supabase
# ==========================
SUPABASE_TABLE_PIVOT=fib_pivot_daily
PIVOT_TABLE=fib_pivot_daily
OPP_TABLE=fib_pivot_opportunities

# ==========================
# WebSocket / Binance
# ==========================
SYMBOL_WS=btcusdt        # Símbolo en minúsculas para el WebSocket de Binance
SYMBOL_DB=BTCUSDT        # Símbolo en mayúsculas para guardar en BD
INTERVAL=1m              # Intervalo de velas (1m, 5m, 15m, etc.)

# ==========================
# Parámetros de detección de oportunidades
# ==========================
TOUCH_BUFFER_BPS=2       # Buffer de toque en puntos básicos
REBOUND_BPS=6            # Rebote mínimo en puntos básicos
CONFIRM_TICKS=3          # Ticks de confirmación antes de registrar oportunidad

# ==========================
# Take Profit / Stop Loss
# ==========================
TP_USDT=200              # Take profit en USDT
SL_USDT=100              # Stop loss en USDT
